{
  "name": "catchline",
  "version": "1.0.0",
  "private": true,
  "description": "Catchline, missed-call recovery for dental clinics. When a clinic misses a call, the patient gets an instant text and the front desk gets paged.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.45.4",
    "next": "15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "twilio": "^5.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
