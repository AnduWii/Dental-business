# =====================================================================
# Catchline, environment variables
# Copy to `.env.local` for local dev, and set the same keys in Vercel.
# NEVER commit real secrets. .env.local is gitignored.
# =====================================================================

# ---- App ----
# Public base URL of the deployment (used to validate Twilio webhook signatures).
# Local dev with a tunnel (ngrok): https://<subdomain>.ngrok.app
# Production: https://app.trycatchline.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (Database + Auth) ----
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses Row Level Security. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Twilio (SMS + Voice) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Optional: a Messaging Service SID (recommended for 10DLC). If set, SMS sends via the service.
TWILIO_MESSAGING_SERVICE_SID=

# ---- AI intake ----
# Provider: "openai" (default) or "anthropic". Leave the key blank to run in
# deterministic fallback mode (scripted questions, no LLM), the product still works.
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Clinic notifications (optional email) ----
# If RESEND_API_KEY is set, the clinic also gets an email page alert. SMS paging works without it.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=alerts@trycatchline.com
